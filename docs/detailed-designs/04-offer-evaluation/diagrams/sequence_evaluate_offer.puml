@startuml sequence_evaluate_offer
!theme plain
skinparam sequenceMessageAlign center

title Evaluate Offer — Main Workflow

actor "Job Seeker" as user
participant "Invoke-OfferEvaluation.ps1" as script
participant "Template Copier" as copier
participant "Editor" as editor
participant "Score Invoker" as scorer
participant "Save Invoker" as saver

user -> script : Invoke-OfferEvaluation\n--company Acme --role Architect
script -> script : Validate params\nGenerate slug
script -> copier : Copy offer-eval-template.md\nto working path
copier --> script : Working file path
script -> editor : Open file in $EDITOR\n(wait for close)
editor --> user : Template open for editing
user -> editor : Fill in ratings and notes
editor --> script : Editor closed
script -> scorer : Compute-OfferScore\n(working file path)
scorer --> script : ScoreResult\n(score, label, action)
script -> saver : Save-EvaluationReport\n(file, company, role)
saver --> script : Final saved path
script -> script : Update pipeline.md\nReport Link column
script --> user : Evaluation complete\nScore: 4.2 — Viable — Review

@enduml
