@startuml sequence_save_evaluation
!theme plain
skinparam sequenceMessageAlign center

title Save Evaluation — Versioning and DB Persist

participant "Save-EvaluationToDb" as saver
database "orbit.db\noffer_evaluations" as EvalDB
database "orbit.db\npipeline_entries" as PipeDB

saver -> EvalDB : SELECT id, version FROM offer_evaluations\nWHERE company=? AND role=?\nAND superseded_by IS NULL

alt Prior row found (re-evaluation)
    EvalDB --> saver : { prior_id, prior_version }
    saver -> EvalDB : INSERT INTO offer_evaluations\n(company, role, eval_date, ...,\nversion = prior_version + 1,\nsuperseded_by = NULL)
    EvalDB --> saver : new_id
    saver -> EvalDB : UPDATE offer_evaluations\nSET superseded_by = new_id\nWHERE id = prior_id
    EvalDB --> saver : 1 row updated
else No prior row (first evaluation)
    EvalDB --> saver : (empty)
    saver -> EvalDB : INSERT INTO offer_evaluations\n(company, role, eval_date, ..., version = 1)
    EvalDB --> saver : new_id
end

saver -> PipeDB : UPDATE pipeline_entries\nSET eval_id = new_id,\nupdated_at = datetime('now')\nWHERE company=? AND role=?
PipeDB --> saver : rows affected
saver --> saver : Return new_id

@enduml
