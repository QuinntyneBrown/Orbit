@startuml sequence_add_entry
!theme plain
skinparam sequenceMessageAlign center

title Sequence — Add Pipeline Entry

actor Candidate
participant "build-resume.ps1\n(Feature 02)" as Build
participant "Invoke-PipelineDb.psm1" as Module
database "orbit.db\npipeline_entries" as DB

Candidate -> Build : Invoke -InputFile <path> [-PDF]
Build --> Candidate : DOCX (and PDF) written to resumes/ and exports/

Candidate -> Module : Add-PipelineEntry\n(Company, Role, Source,\nAppliedDate, Status, PdfPath)
Module -> DB : SELECT MAX(seq_no) + 1 FROM pipeline_entries
DB --> Module : next seq_no
Module -> DB : INSERT INTO pipeline_entries\n(seq_no, applied_date, company, role,\nsource, status, pdf_path)\nVALUES (?, ?, ?, ?, ?, ?, ?)
alt CHECK constraint violation (invalid status)
    DB --> Module : SQLITE_CONSTRAINT
    Module --> Candidate : ERROR: invalid status value
else Insert succeeded
    DB --> Module : new row id
    Module --> Candidate : Entry added (id = N, seq_no = M)
end

@enduml
