@startuml sequence_update_status
!theme plain
skinparam sequenceMessageAlign center

title Sequence — Update Application Status

actor Candidate
participant "Invoke-PipelineDb.psm1" as Module
database "orbit.db\npipeline_entries" as DB

Candidate -> Module : Update-PipelineStatus\n(-Id N, -Status "Responded")
Module -> DB : UPDATE pipeline_entries\nSET status = ?,\nupdated_at = datetime('now')\nWHERE id = ?
alt CHECK constraint violation
    DB --> Module : SQLITE_CONSTRAINT error
    Module --> Candidate : ERROR: invalid status value
else 0 rows affected (id not found)
    DB --> Module : 0 rows affected
    Module --> Candidate : WARNING: no row with id = N
else 1 row updated
    DB --> Module : 1 row affected
    Module --> Candidate : Status updated to Responded
end

@enduml
