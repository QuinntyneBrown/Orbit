@startuml sequence_update_recruiter
!theme plain
skinparam sequenceMessageAlign center

title Sequence — Update a Recruiter Record

actor Candidate
participant "Invoke-UpdateRecruiter.ps1" as Script
database "orbit.db\nrecruiter_contacts" as DB

Candidate -> Script : Invoke-UpdateRecruiter\n--name "Jane Smith"\n--status "Active"\n--note "Followed up re: contract role"

Script -> DB : SELECT id, name, agency,\n  engagement_status, last_contacted_date\nFROM recruiter_contacts\nWHERE name = ? COLLATE NOCASE
DB --> Script : existing record (or empty)

alt Recruiter not found
    Script --> Candidate : ERROR: No recruiter found matching "<name>".\nUse Invoke-AddRecruiter to create a new record.
else Record found
    Script -> DB : UPDATE recruiter_contacts\nSET last_contacted_date = date('now'),\n  engagement_status = ?,\n  notes = ?,\n  updated_at = datetime('now')\nWHERE id = ?
    DB --> Script : 1 row updated

    Script -> DB : SELECT days since last_contacted_date,\n  priority_tier\nFROM recruiter_contacts WHERE id = ?
    DB --> Script : { days_since_contact, priority_tier }

    Script --> Candidate : Record updated.\nNext follow-up due in N days\n(priority: <tier>)
end

@enduml
