@startuml sequence_persist_results
!theme plain
skinparam sequenceMessageAlign center

title Sequence — Persist Search Results (L2-014)

participant "SearchOrchestrator" as Orch
participant "HistoryStore" as Store
database "orbit.db\nscan_runs\njob_listings" as DB

Orch -> Store : Invoke-HistoryPersist(scanRunId, results[])
Store -> DB : BEGIN TRANSACTION

loop for each result (normalised company + title)
    Store -> DB : INSERT INTO job_listings\n(scan_run_id, title, company, source,\nposted_date, rate, url,\nstatus='New', first_seen_date=today,\nlast_seen_date=today)\nON CONFLICT (company, title) DO UPDATE SET\n  last_seen_date = today,\n  status = CASE WHEN status='Applied'\n           THEN 'Applied' ELSE 'Seen' END,\n  scan_run_id = excluded.scan_run_id
    DB --> Store : insert or update applied
end

Store -> DB : UPDATE scan_runs\nSET total_results=?, new_listings=?,\nseen_listings=?\nWHERE id=?
DB --> Store : updated
Store -> DB : COMMIT
DB --> Store : transaction complete
Store --> Orch : DeduplicationResult\n{ New, Seen, AppliedProtected }

@enduml
