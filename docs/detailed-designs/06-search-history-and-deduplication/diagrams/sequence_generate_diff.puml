@startuml sequence_generate_diff
!theme plain
skinparam sequenceMessageAlign center

title Sequence — Generate Run Diff (L2-015)

participant "SearchOrchestrator" as Orch
participant "DiffGenerator" as Diff
database "orbit.db\nscan_runs\njob_listings" as DB

Orch -> Diff : ComputeDiff(currentScanRunId)

Diff -> DB : SELECT id FROM scan_runs\nORDER BY started_at DESC\nLIMIT 2
DB --> Diff : [currentRunId, previousRunId] (or just [currentRunId])

alt fewer than 2 scan_runs
    Diff --> Orch : RunDiff { IsFirstRun = true }
else
    Diff -> DB : SELECT company, title, status\nFROM job_listings\nWHERE scan_run_id = previousRunId
    DB --> Diff : previousRecords[]

    Diff -> DB : SELECT company, title, status\nFROM job_listings\nWHERE scan_run_id = currentRunId
    DB --> Diff : currentRecords[]

    Diff -> Diff : newListings = current - previous (by company+title)
    Diff -> Diff : removedListings = previous - current (by company+title)
    Diff -> Diff : changedListings = same key, different status
    Diff --> Orch : RunDiff { New, Removed, Changed }
end

Orch -> DB : SELECT total_results, new_listings, seen_listings\nFROM scan_runs WHERE id = currentScanRunId
DB --> Orch : scan summary

Orch -> DB : DELETE FROM scan_runs\nWHERE id NOT IN (\n  SELECT id FROM scan_runs\n  ORDER BY started_at DESC\n  LIMIT :resultHistoryWindow\n)
DB --> Orch : old runs pruned

@enduml
