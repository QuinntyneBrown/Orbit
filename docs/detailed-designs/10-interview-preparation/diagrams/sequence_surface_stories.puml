@startuml sequence_surface_stories
!theme plain
skinparam sequenceMessageAlign center

title Sequence — Surface Relevant Stories for Interview/Offer Role

actor Candidate
participant "Invoke-SurfaceStories.ps1" as Script
database "orbit.db\npipeline_entries\noffer_evaluations\ninterview_stories" as DB

Candidate -> Script : Invoke-SurfaceStories

Script -> DB : SELECT pe.company, pe.role,\n  oe.jd_keywords_json\nFROM pipeline_entries pe\nLEFT JOIN offer_evaluations oe\n  ON pe.eval_id = oe.id\nWHERE pe.status IN ('Interview', 'Offer')
DB --> Script : qualifying roles[]

alt no qualifying roles
    Script --> Candidate : No roles in Interview or Offer state.
else roles found
    loop For each qualifying role
        Script -> DB : SELECT id, title, keywords_json\nFROM interview_stories
        DB --> Script : all stories[]

        Script -> Script : Count total stories\n(warn if < 3)
        Script -> Script : For each story:\n  overlap = intersect(story.keywords, jd.keywords)\n  score = |overlap|
        Script -> Script : Sort descending by score;\ntake top N stories

        Script --> Candidate : Output role header +\nranked story matches\n+ overlap keyword list
    end
end

@enduml
