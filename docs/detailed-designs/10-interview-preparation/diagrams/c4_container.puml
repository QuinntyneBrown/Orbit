@startuml c4_container
!theme plain
!include <C4/C4_Container>

title C4 Container — Feature 10: Interview Preparation

Person(candidate, "Candidate", "Authors stories and reviews surfaced results.")

System_Boundary(orbit, "Orbit Career Management") {
    Container(storyBank, "Story Bank", "Markdown File", "interview-prep/story-bank.md — cumulative STAR+Reflection behavioral stories with keyword tags.")
    Container(pipeline, "Application Pipeline", "Markdown File", "data/pipeline.md — tracks role state transitions (Applied, Interview, Offer, etc.).")
    Container(jobSkill, "job-search Skill", "Claude Code / JavaScript", "Orchestrates job search, evaluates roles, surfaces interview stories.")
    Container(evaluations, "Role Evaluations", "Markdown Files", "content/evaluations/<slug>.md — JD text and keyword extracts per role.")
}

Rel(candidate, storyBank, "Appends new STAR+Reflection stories", "Markdown editor")
Rel(candidate, jobSkill, "Triggers story surfacing", "CLI")
Rel(jobSkill, storyBank, "Reads all stories", "File I/O")
Rel(jobSkill, pipeline, "Reads role state", "File I/O")
Rel(jobSkill, evaluations, "Reads JD keywords", "File I/O")

@enduml
